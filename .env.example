# SmartRAG Environment Configuration
# Copy this file to .env and modify as needed.
# NEVER commit .env to version control.

# --- Server ---
SMARTRAG_PORT=8000
SMARTRAG_HOST=0.0.0.0
SMARTRAG_KNOWLEDGE_DIR=./knowledge
SMARTRAG_CORS_ORIGINS=*
SMARTRAG_RATE_LIMIT=100
SMARTRAG_LOG_LEVEL=INFO

# --- Embeddings (optional) ---
# Set to "true" to enable semantic embeddings (requires smartrag[embeddings])
SMARTRAG_EMBEDDINGS_ENABLED=false

# --- LLM Provider (optional, for enhanced fingerprinting) ---
# Supported: "openai", "anthropic", "ollama"
# SMARTRAG_LLM_PROVIDER=
# SMARTRAG_LLM_API_KEY=
